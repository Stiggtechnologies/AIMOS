# ============================================================
# AIMOS environment variables (Vite). Copy to `.env` for local dev.
# ============================================================

# --- Supabase (required) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Demo / placeholder data ---
# Several dashboards synthesize illustrative metrics where a real data source
# has not been wired yet (see src/lib/demoData.ts). When enabled, values are
# deterministic per entity (stable across renders). Set to false in production
# to surface real-data gaps as empty/zeroed state instead of fabricated numbers.
# Defaults to true when unset.
VITE_ENABLE_DEMO_DATA=true
